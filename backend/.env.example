# Environment
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env

# PostgreSQL connection string (required)
# Example local: postgresql://postgres:postgres@localhost:5432/assetflow?schema=public
# Example Prisma Postgres: postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require
DATABASE_URL=

# JWT signing secret (required) — use a long random string in production
JWT_SECRET=

# HTTP port the API listens on (default: 3001)
PORT=3001

# Runtime environment: development | production | test
NODE_ENV=development
